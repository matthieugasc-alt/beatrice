# ---------------------------------------------------------------------------
# beatrice / factures-v1 — variables d'environnement
# ---------------------------------------------------------------------------
# Copier ce fichier en .env et remplir les valeurs réelles.
# Le .env n'est JAMAIS versionné (voir .gitignore).
# ---------------------------------------------------------------------------

# Clé API requise pour POST /upload et signature HMAC des URLs.
# Génère-la avec : python -c "import secrets; print(secrets.token_hex(32))"
API_KEY=

# Port HTTP exposé par Flask (par défaut 8080 dans l'image Docker)
PORT=8080

# Niveau de log Flask ; debug uniquement en dev local
FLASK_ENV=production
FLASK_DEBUG=0

# Si tu pousses vers Pennylane depuis l'app (cf. champ pennylane_status du log)
# PENNYLANE_API_TOKEN=
# PENNYLANE_COMPANY_ID=
